{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Polly": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "MetricsApi": {
    "BaseUrl": "http://localhost:8080",
    "ApiKey": "supersecret",
    "PollIntervalSeconds": 30,
    "RequestTimeoutSeconds": 30
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "QueueName": "meter.readings"
  }
}
